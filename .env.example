# LLM Provider (required)
GEMINI_API_KEY=your_gemini_api_key_here
LLM_MODEL=gemini-2.5-pro
LLM_MODEL_FAST=gemini-2.5-flash

# Search API (optional but recommended — Tavily is preferred)
TAVILY_API_KEY=your_tavily_api_key_here             # FREE TIER: 1000 credits/month at tavily.com
SERPAPI_KEY=your_serpapi_key_here                    # PAID ONLY: $50/month for 5000 searches

# Email Discovery APIs
# HIBP_API_KEY=your_hibp_key_here                    # PAID ONLY: $3.50/month - breach detection
HUNTER_API_KEY=your_hunter_api_key_here              # FREE TIER: 25 searches/month, then paid

# Social Media APIs for enhanced data collection
GITHUB_TOKEN=your_github_token_here                  # FREE TIER: higher rate limits
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here  # FREE TIER: basic access available
YOUTUBE_API_KEY=your_youtube_api_key_here            # FREE TIER: 10,000 units/day
TELEGRAM_API_ID=your_telegram_api_id_here            # FREE TIER: obtain from my.telegram.org
TELEGRAM_API_HASH=your_telegram_api_hash_here
TELEGRAM_PHONE=your_telegram_phone_with_country_code # e.g. +1234567890
# INSTAGRAM_ACCESS_TOKEN=your_instagram_token_here   # FREE TIER: requires business account

# Quick Start Recommendation: Enable YouTube + GitHub first (both free, no approval needed)
